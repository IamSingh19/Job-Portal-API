# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Job Portal API"
APP_VERSION="1.0.0"
DEBUG=false

# ─── Database (MySQL) ─────────────────────────────────────────────────────────
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/job_portal

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate strong random secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_strong_random_secret_key_here
REFRESH_SECRET_KEY=CHANGE_ME_generate_a_different_strong_random_secret_key

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Uploads ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=5
